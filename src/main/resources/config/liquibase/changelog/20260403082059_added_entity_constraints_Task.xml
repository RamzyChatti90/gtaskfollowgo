<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Task.
    -->
    <changeSet id="20260403082059-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="assigned_to_id"
                                 baseTableName="task"
                                 constraintName="fk_task__assigned_to_id"
                                 referencedColumnNames="id"
                                 referencedTableName="app_user"
                                 />

        <addForeignKeyConstraint baseColumnNames="task_id"
                                 baseTableName="rel_task__tag"
                                 constraintName="fk_rel_task__tag__task_id"
                                 referencedColumnNames="id"
                                 referencedTableName="task"
                                 />

        <addForeignKeyConstraint baseColumnNames="tag_id"
                                 baseTableName="rel_task__tag"
                                 constraintName="fk_rel_task__tag__tag_id"
                                 referencedColumnNames="id"
                                 referencedTableName="tag"
                                 />
    </changeSet>
</databaseChangeLog>
